{
  "manifestVersion": 1,
  "id": "atlas-action",
  "name": "Atlas Actions",
  "version": "1.10.0",
  "description": "Atlas Action for Azure DevOps Pipeline",
  "publisher": "ariga",
  "categories": [
    "Azure Pipelines"
  ],
  "icons": {
    "default": "atlas.png"
  },
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "files": [
    {
      "path": "action"
    }
  ],
  "contributions": [
    {
      "id": "atlas-action",
      "type": "ms.vss-distributed-task.task",
      "targets": [
        "ms.vss-distributed-task.tasks"
      ],
      "properties": {
        "name": "action"
      }
    }
  ]
}
