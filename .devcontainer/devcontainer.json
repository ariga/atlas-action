{
	"name": "Go",
	"image": "mcr.microsoft.com/devcontainers/go:2-1.26-bookworm",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {},
		"ghcr.io/devcontainers/features/copilot-cli:1": {
			"version": "latest"
		}
	},
	"mounts": [
		{
			"type": "volume",
			"source": "go-mod-cache",
			"target": "/go/pkg/mod"
		},
		{
			"type": "volume",
			"source": "${localWorkspaceFolderBasename}-worktrees",
			"target": "/workspaces/${localWorkspaceFolderBasename}.worktrees"
		}
	],
	"postCreateCommand": {
		"go-mod-owner": "sudo chown -R $(id -u):$(id -g) /go/pkg",
		"workspaces": "sudo chown -R $(id -u):$(id -g) /workspaces/${localWorkspaceFolderBasename}.worktrees"
	},
	"postStartCommand": {
		"install-goimports": "go install golang.org/x/tools/cmd/goimports@v0.45.0"
	}
}