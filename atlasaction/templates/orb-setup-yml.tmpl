description: >
  This command will install the Atlas CLI and authenticate to Atlas Cloud if a cloud token is provided.
  This command require curl to be installed on the machine.

parameters:
  version:
    type: string
    default: "latest"
    description: 'Which version of Atlas to install, in the format of "v0.14.1"'
  cloud_token_env:
    type: env_var_name
    default: ATLAS_TOKEN
    description: |
      Environment variable containing the Atlas Cloud token.
      If provided, the command will authenticate to Atlas Cloud.
      (e.g. `ATLAS_TOKEN`)
steps:
  - restore_cache:
      keys:
        - atlas-grant-cache-
  - run:
      name: Install Atlas CLI
      command:
        curl -sSf https://atlasgo.sh | sh
      environment:
        ATLAS_VERSION: <<parameters.version>>
  - run:
      name: Download Atlas Action
      command: |
        # Download the binary (primary: atlasbinaries.com, fallback: release.ariga.io)
        curl -sf -o atlasaction https://atlasbinaries.com/atlas-action/atlas-action-v{{ .Version }} || \
          curl -sf -o atlasaction https://release.ariga.io/atlas-action/atlas-action-v{{ .Version }}
        # Install the binary in path
        sudo install -o root -g root -m 0755 ./atlasaction /bin/atlasaction
  - run:
      name: Authenticate to Atlas Cloud
      command: |
        if [ -z "${<<parameters.cloud_token_env>>}" ]; then
          echo "No cloud token provided, skipping authentication."
          exit 0
        fi
        atlas login --token ${<<parameters.cloud_token_env>>} --grant-only
  - run:
      name: Expose Grant
      command:
        echo 'export ATLAS_TOKEN="${<< parameters.cloud_token_env >>}"' >> $BASH_ENV
  - persist_to_workspace:
      root: ~/
      paths:
        - .atlas
  - save_cache:
      key: atlas-grant-cache-<< pipeline.id >>
      paths:
        - ~/.atlas
