# Generated by go run ./cmd/gen teamcity-template; DO NOT EDIT.
name: ariga/atlas-{{ .ID | replace "/" "-" }}
title: Atlas {{ .Name }}
version: {{ .Version }}
description: >
  {{ .Description }}
inputs:
  - env.INSTALL_PATH:
      type: text
      label: Installation Path
      description: >
        The installation path for Atlas CLI and Atlas Action binaries.
        Uses agent's tools directory by default for caching across builds.
      default: "%teamcity.agent.tools.dir%/atlas"
  - env.ATLAS_VERSION:
      type: text
      label: Atlas Version
      description: The version of Atlas CLI to install.
      default: latest
{{- if ne .ID "monitor/schema" }}
  - env.ATLAS_TOKEN:
      type: password
      label: Atlas Cloud Token
      description: Atlas Cloud token for authentication.
      required: false
{{- end }}
{{- range $name, $input := .SortedInputs }}
  - env.{{ $name | inputvar }}:
{{- if eq $input.Type "boolean" }}
      type: boolean
{{- else if $input.Options }}
      type: select
      options:
        {{- range $v := $input.Options }}
        - {{ $v }}
        {{- end }}
{{- else if or (eq $input.Type "password") (contains $name "token") }}
      type: password
{{- else }}
      type: text
{{- end }}
      label: {{ with $input.Label }}{{ . }}{{ else }}{{ $name }}{{ end }}
      description: >
        {{ $input.Description | nl2sp | trimnl }}
      required: {{ $input.Required }}
{{- if $input.Default }}
      default: "{{ $input.Default }}"
{{- end }}
{{- end }}
steps:
  - name: Setup Atlas CLI and Atlas Action
    script: |
      #!/bin/bash
      set -e
      # Setup Atlas CLI
      ATLAS_INSTALL_DIR="$INSTALL_PATH/atlas-$ATLAS_VERSION"
      ATLAS_BINARY="$ATLAS_INSTALL_DIR/atlas"
      if "$ATLAS_BINARY" version &>/dev/null; then
        echo "Atlas CLI $ATLAS_VERSION is already installed at $ATLAS_INSTALL_DIR"
      else
        echo "Installing Atlas CLI version: $ATLAS_VERSION"
        mkdir -p "$ATLAS_INSTALL_DIR"
        curl -sSf https://atlasgo.sh | ATLAS_VERSION="$ATLAS_VERSION" sh -s -- -y -o "$ATLAS_BINARY"
      fi
{{- if ne .ID "monitor/schema" }}
      # Authenticate with Atlas Cloud if token is provided
      if [ -n "$ATLAS_TOKEN" ]; then
        echo "Authenticating with Atlas Cloud..."
        "$ATLAS_BINARY" login --token "$ATLAS_TOKEN"
      fi
{{- end }}
      # Setup Atlas Action binary
      {{- $actionVersion := .Version | majorver | printf "v%s" }}
      ACTION_INSTALL_DIR="$INSTALL_PATH/atlas-action-{{ $actionVersion }}"
      ACTION_BINARY="$ACTION_INSTALL_DIR/atlas-action"
      # Detect platform
      OS=$(uname -s | tr '[:upper:]' '[:lower:]')
      ARCH=$(uname -m)
      case "$ARCH" in
        x86_64)   ARCH="amd64" ;;
        aarch64|arm64) ARCH="arm64" ;;
        *)
          echo "Unsupported architecture: $ARCH"
          exit 1
          ;;
      esac
      BINARY_NAME="atlas-action-${OS}-${ARCH}-{{ $actionVersion }}"
      if "$ACTION_BINARY" --version &>/dev/null; then
        echo "Atlas Action {{ $actionVersion }} is already installed at $ACTION_INSTALL_DIR"
      else
        echo "Downloading Atlas Action {{ $actionVersion }}..."
        mkdir -p "$ACTION_INSTALL_DIR"
        DOWNLOAD_URL="https://release.ariga.io/atlas-action/${BINARY_NAME}"
        if curl -L -o "$ACTION_BINARY" --fail "-#" "$DOWNLOAD_URL"; then
          chmod +x "$ACTION_BINARY"
          echo "Atlas Action downloaded successfully"
        else
          echo "Failed to download atlas-action from $DOWNLOAD_URL" >&2
          exit 1
        fi
      fi
      # Update PATH for subsequent build steps using TeamCity service message
      NEW_PATH="$ATLAS_INSTALL_DIR:$ACTION_INSTALL_DIR"
      if [ -n "$TEAMCITY_PATH_PREFIX" ]; then
        NEW_PATH="$NEW_PATH:$TEAMCITY_PATH_PREFIX"
      fi
      echo "##teamcity[setParameter name='env.TEAMCITY_PATH_PREFIX' value='$NEW_PATH']"
  - name: Run {{ .Name }}
    script: atlas-action --action={{ .ID }}
