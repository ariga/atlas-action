# Generated by go run ./cmd/gen orb-template; DO NOT EDIT.
description: >
  {{ .Description }}

parameters:
{{- range $name, $input := .SortedInputs }}
{{- if or (ne $.ID "monitor/schema") (ne $name "cloud-token") }}
  {{ $name | orbparam }}:
    type: {{ $input | orbtype }}
    default: {{ if $input.Default }}{{ if eq $input.Type "boolean" }}{{ $input.Default }}{{ else }}'{{ $input.Default }}'{{ end }}{{ else }}{{ if eq $name "working-directory" }}'.'{{ else }}{{ if eq $input.Type "boolean" }}false{{ else }}''{{ end }}{{ end }}{{ end }}
    description: |
      {{ $input.Description | trimnl }}
{{- if $input.Options }}

    enum:
      {{- range $v := $input.Options }}
      - {{ $v }}
      {{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- if needGitHubEnv .ID }}
  github_repo_env:
    type: env_var_name
    default: GITHUB_REPOSITORY
    description: |
      The repository name that linting results will be posted to.
  github_token_env:
    type: env_var_name
    default: GITHUB_TOKEN
    description: |
      Environment variable containing the GitHub token.
      If provided, the command will authenticate to GitHub.
      (e.g. `GITHUB_TOKEN`)
{{- end }}
{{- if eq .ID "monitor/schema" }}
  cloud_token_env:
    type: env_var_name
    default: ATLAS_TOKEN
    description: |
      Environment variable containing the Atlas Cloud token.
      If provided, the command will authenticate to Atlas Cloud.
      (e.g. `ATLAS_TOKEN`)
{{- end }}

steps:
  - run:
      name: {{ .Name }}
      command: |
{{- if needGitHubEnv .ID }}
        # replace GITHUB_REPOSITORY with the github_repo_env if provided
        if [ -n "${<<parameters.github_repo_env>>}" ]; then
          GITHUB_REPOSITORY=${<<parameters.github_repo_env>>}
        fi
        # replace GITHUB_TOKEN with the github_token_env if provided
        if [ -n "${<<parameters.github_token_env>>}" ]; then
          GITHUB_TOKEN=${<<parameters.github_token_env>>}
        fi
{{- end }}
{{- if eq .ID "monitor/schema" }}
        ATLAS_INPUT_CLOUD_TOKEN=${<<parameters.cloud_token_env>>}
{{- end }}
        atlasaction --action {{ .ID }}
      environment:
{{- range $name, $input := .SortedInputs }}
{{- if or (ne $.ID "monitor/schema") (ne $name "cloud-token") }}
        {{ $name | inputvar }}: <<parameters.{{ $name | orbparam }}>>
{{- end }}
{{- end }}
