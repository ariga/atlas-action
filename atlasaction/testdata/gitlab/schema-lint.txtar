# Test schema/lint action for GitLab
# Mock the atlas command outputs
env ATLAS_PATH=$MOCK_ATLAS TEST_BATCH=./schema-lint
# Setup the action input variables
env ATLAS_INPUT_URL=file://schema.hcl
env ATLAS_INPUT_DEV_URL=sqlite://file?mode=memory
# Setup merge request environment
env CI_MERGE_REQUEST_IID=1
env CI_PROJECT_NAME=my-project
env CI_PROJECT_URL=https://gitlab.com/projects/my-project
env CI_COMMIT_REF_NAME=test-branch
env CI_COMMIT_SHA=123
env GITLAB_USER_NAME=user
env GITLAB_USER_ID=123
env CI_MERGE_REQUEST_REF_PATH=$CI_PROJECT_URL/merge_requests/1

# Run schema lint action - expect success with warnings
atlas-action --action=schema/lint
stdout '`atlas schema lint` completed successfully with 1 warnings'

cmp comments-expected/1 comments/1

-- schema-lint/1/args --
schema lint --format {{ json . }} --dev-url sqlite://file?mode=memory --url file://schema.hcl
-- schema-lint/1/stdout --
{"Steps":[{"Text":"naming","Diagnostics":[{"Pos":{"Filename":"schema.hcl","Start":{"Line":5,"Column":1}},"Text":"Table name should use snake_case","Code":"NM101"}]}]}
-- comments-expected/1 --
<code>atlas schema lint</code> on <strong>file://schema.hcl</strong>
